<Window x:Class="MyPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyPlayer.App"
        Title="MyPlayer"
        Width="1120"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        Background="#101010"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_OnDragEnter"
        DragOver="Window_OnDragEnter"
        Drop="Window_OnDrop"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Loaded="Window_OnLoaded"
        Closing="Window_OnClosing"
        SourceInitialized="Window_OnSourceInitialized">
    <Grid Background="#101010">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="12"
                Background="Black"
                BorderBrush="#2C2C2C"
                BorderThickness="1"
                CornerRadius="10"
                SnapsToDevicePixels="True">
            <Grid>
                <local:VideoHost x:Name="VideoHostControl" />

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="24,18"
                        MaxWidth="480"
                        Background="#990D0D0D"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding OverlayVisibility}"
                        IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock Text="{Binding OverlayTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding OverlayMessage}"
                                   FontSize="14"
                                   Foreground="#D0D0D0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="12,0,12,12"
                Padding="20,16"
                Background="#171717"
                BorderBrush="#2C2C2C"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="{Binding CurrentTimeText}" />

                    <Grid Grid.Column="1"
                          x:Name="SeekSurface"
                          Height="24"
                          Background="Transparent"
                          Cursor="Hand"
                          SizeChanged="SeekSurface_OnSizeChanged"
                          MouseLeftButtonDown="SeekSurface_OnMouseLeftButtonDown"
                          MouseMove="SeekSurface_OnMouseMove"
                          MouseLeftButtonUp="SeekSurface_OnMouseLeftButtonUp"
                          LostMouseCapture="SeekSurface_OnLostMouseCapture">
                        <Border Height="6"
                                Background="#3A3A3A"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                        <Border x:Name="SeekProgressFill"
                                Width="0"
                                Height="6"
                                HorizontalAlignment="Left"
                                Background="White"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                        <Ellipse x:Name="SeekThumb"
                                 Width="14"
                                 Height="14"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Fill="White"
                                 Stroke="#101010"
                                 StrokeThickness="1.5"
                                 Margin="0,0,0,0" />
                    </Grid>

                    <TextBlock Grid.Column="2"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="{Binding DurationText}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button MinWidth="64" Margin="0,0,10,0" Padding="14,8" Click="OpenButton_OnClick">打开</Button>
                        <Button MinWidth="64" Margin="0,0,10,0" Padding="14,8" Click="RewindButton_OnClick">-10 秒</Button>
                        <Button MinWidth="64" Margin="0,0,10,0" Padding="14,8" Click="PlayPauseButton_OnClick" Content="{Binding PlayPauseButtonText}" />
                        <Button MinWidth="64" Margin="0,0,10,0" Padding="14,8" Click="ForwardButton_OnClick">+10 秒</Button>
                        <Button MinWidth="64" Margin="0,0,10,0" Padding="14,8" Click="MuteButton_OnClick" Content="{Binding MuteButtonText}" />
                        <Button MinWidth="64" Padding="14,8" Click="FullscreenButton_OnClick" Content="{Binding FullscreenButtonText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding PlaybackBadge}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding StatusText}"
                                   FontSize="13"
                                   Foreground="#CFCFCF"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="倍速" />
                        <ComboBox Width="92"
                                  Margin="0,0,18,0"
                                  ItemsSource="{Binding SpeedOptions}"
                                  SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}"
                                  ItemStringFormat="{}{0:0.##}x"
                                  SelectionChanged="SpeedComboBox_OnSelectionChanged" />
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="音量" />
                        <Slider x:Name="VolumeSlider"
                                Width="160"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding Volume, Mode=TwoWay}"
                                IsMoveToPointEnabled="True"
                                TickFrequency="5"
                                IsSnapToTickEnabled="False"
                                ValueChanged="VolumeSlider_OnValueChanged"
                                PreviewMouseLeftButtonDown="VolumeSlider_OnPreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="VolumeSlider_OnPreviewMouseLeftButtonUp" />
                        <TextBlock Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding VolumeText}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
